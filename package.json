{
  "name": "duckling",
  "version": "0.1.0",
  "description": "A lightweight notifier and approval tool for Claude Code via Telegram.",
  "license": "MIT",
  "bin": {
    "duckling": "dist/cli/index.js"
  },
  "main": "dist/cli/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run typecheck:worker",
    "build:cli": "tsc",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "watch": "tsc --watch",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:tail": "wrangler tail",
    "upgrade": "bash scripts/upgrade.sh",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.37",
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240821.1",
    "@types/node": "^20.14.0",
    "@types/prompts": "^2.4.9",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0"
  }
}
